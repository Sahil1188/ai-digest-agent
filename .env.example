# ─────────────────────────────────────────────────────────────
# AI Digest — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it's in .gitignore already.
# ─────────────────────────────────────────────────────────────

# ── LLM Keys (both are FREE, no credit card needed) ──────────

# Gemini 2.5 Flash (primary LLM)
# Get it at: https://aistudio.google.com/apikey
# Free tier: 15 requests/min, 1M tokens/day
GEMINI_API_KEY=your_gemini_api_key_here

# Groq Llama 3.3 70B (fallback LLM)
# Get it at: https://console.groq.com/keys
# Free tier: 14,400 requests/day
GROQ_API_KEY=your_groq_api_key_here

# ── Gmail SMTP (for sending the digest email) ─────────────────

# Your Gmail address (the "From" address)
GMAIL_ADDRESS=yourname@gmail.com

# Gmail App Password — NOT your Google account password.
# You must enable 2FA on your Google account first, then:
# 1. Go to https://myaccount.google.com/security
# 2. Under "How you sign in to Google" → click "2-Step Verification"
# 3. Scroll to the bottom → "App passwords"
# 4. Select app: "Mail", device: "Other" → type "AI Digest"
# 5. Copy the 16-character password shown (no spaces)
GMAIL_APP_PASSWORD=abcd efgh ijkl mnop

# Who receives the digest (can be the same as GMAIL_ADDRESS)
RECIPIENT_EMAIL=yourname@gmail.com

# ── Reddit API (optional — digest runs fine without it) ───────

# How to get Reddit API credentials:
# 1. Go to https://www.reddit.com/prefs/apps
# 2. Scroll to bottom → click "create another app..."
# 3. Name: "AI Digest Bot" (or anything)
# 4. Type: select "script"
# 5. Description: leave blank
# 6. About URL: leave blank
# 7. Redirect URI: http://localhost:8080
# 8. Click "create app"
# 9. REDDIT_CLIENT_ID = the short string under "personal use script"
# 10. REDDIT_CLIENT_SECRET = the "secret" field
# 11. REDDIT_USER_AGENT = a descriptive string (see below)
#
# If these are left empty/missing, Reddit is skipped silently — no crash.
REDDIT_CLIENT_ID=your_client_id_here
REDDIT_CLIENT_SECRET=your_client_secret_here

# User agent format Reddit recommends: platform:app_name:version (by u/username)
REDDIT_USER_AGENT=python:ai-digest-bot:v1.0 (by u/your_reddit_username)
